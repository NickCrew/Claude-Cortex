{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cortex.dev/schemas/composition.schema.json",
  "$comment": "IDE/editor reference only — NOT validated at runtime. Provides YAML autocomplete and inline diagnostics (VSCode, JetBrains) when editing composition.yaml. To add runtime validation, wire a checker into claude_ctx_py/dev_validate.py.",
  "title": "Skill Composition Map",
  "description": "Defines dependencies between skills for automatic loading",
  "type": "object",
  "patternProperties": {
    "^[a-z0-9-]+$": {
      "oneOf": [
        {
          "type": "array",
          "description": "List of required skill dependencies",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "uniqueItems": true
        },
        {
          "type": "null",
          "description": "No dependencies"
        }
      ]
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "microservices-patterns": [
        "api-design-patterns",
        "event-driven-architecture"
      ],
      "cqrs-event-sourcing": [
        "event-driven-architecture"
      ],
      "simple-skill": null
    }
  ]
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cortex.dev/schemas/activation.schema.json",
  "title": "Skill Activation Configuration",
  "description": "Defines keyword mappings for automatic skill activation",
  "type": "object",
  "required": ["skills"],
  "properties": {
    "skills": {
      "type": "object",
      "description": "Map of skill IDs to their activation keywords",
      "patternProperties": {
        "^[a-z0-9-]+$": {
          "$ref": "#/$defs/skillActivation"
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "skillActivation": {
      "type": "object",
      "required": ["keywords"],
      "properties": {
        "keywords": {
          "type": "array",
          "description": "Keywords/phrases that trigger this skill",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "patterns": {
          "type": "array",
          "description": "Regex patterns for advanced matching",
          "items": {
            "type": "string",
            "format": "regex"
          },
          "uniqueItems": true
        },
        "priority": {
          "type": "integer",
          "description": "Activation priority (higher = preferred)",
          "minimum": 1,
          "maximum": 100,
          "default": 50
        },
        "auto_activate": {
          "type": "boolean",
          "description": "Whether to auto-activate on keyword match",
          "default": true
        }
      },
      "additionalProperties": false
    }
  }
}

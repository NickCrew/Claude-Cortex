{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cortex.dev/schemas/triggers.schema.json",
  "title": "Agent Trigger Configuration",
  "description": "Defines when agents should be automatically suggested or activated",
  "type": "object",
  "required": ["version", "triggers"],
  "properties": {
    "version": {
      "type": "number",
      "description": "Configuration version",
      "minimum": 1.0
    },
    "triggers": {
      "type": "object",
      "description": "Map of agent IDs to their trigger configurations",
      "patternProperties": {
        "^[a-z0-9-]+$": {
          "$ref": "#/$defs/agentTrigger"
        }
      }
    }
  },
  "$defs": {
    "agentTrigger": {
      "type": "object",
      "properties": {
        "keywords": {
          "type": "array",
          "description": "Keywords that trigger this agent",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "file_patterns": {
          "type": "array",
          "description": "Glob patterns for file-based triggering",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "events": {
          "type": "array",
          "description": "Git/lifecycle events that trigger this agent",
          "items": {
            "type": "string",
            "enum": [
              "pre-commit",
              "post-commit",
              "pre-push",
              "post-merge",
              "pre-rebase",
              "post-checkout",
              "file-change",
              "branch-create"
            ]
          },
          "uniqueItems": true
        },
        "auto": {
          "type": "boolean",
          "description": "Whether to auto-activate (true) or just suggest (false)",
          "default": false
        },
        "priority": {
          "type": "string",
          "description": "Suggestion priority level",
          "enum": ["low", "medium", "high", "critical"],
          "default": "medium"
        },
        "conditions": {
          "type": "object",
          "description": "Additional activation conditions",
          "properties": {
            "file_count_min": {
              "type": "integer",
              "description": "Minimum number of matching files",
              "minimum": 0
            },
            "file_count_max": {
              "type": "integer",
              "description": "Maximum number of matching files",
              "minimum": 0
            },
            "branch_pattern": {
              "type": "string",
              "description": "Git branch name pattern (regex)"
            },
            "exclude_patterns": {
              "type": "array",
              "description": "File patterns to exclude",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "context": {
          "type": "object",
          "description": "Additional context to pass to the agent",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/NickCrew/claude-cortex/schemas/onboarding-state.schema.json",
  "title": "Onboarding State",
  "description": "Persisted state for wizard onboarding completion",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "completed_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "ISO 8601 timestamp when onboarding was completed"
    },
    "experience_level": {
      "type": "string",
      "description": "User's self-reported experience level",
      "enum": ["new", "familiar", "expert"],
      "default": "new"
    },
    "profile_applied": {
      "type": "string",
      "description": "Name of the profile that was applied during setup",
      "default": "minimal"
    },
    "tui_tour_shown": {
      "type": "boolean",
      "description": "Whether the TUI tour was shown to the user",
      "default": false
    },
    "version": {
      "type": "string",
      "description": "Schema version for migration purposes",
      "default": "1.0"
    }
  },
  "additionalProperties": false
}

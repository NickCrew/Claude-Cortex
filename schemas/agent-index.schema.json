{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/NickCrew/claude-cortex/schemas/agent-index.schema.json",
  "title": "Agent Index",
  "description": "Generated index of all agents in a Cortex installation, derived from each agent .md file's front matter. Serves as the single source of truth for `cortex hooks agent-suggest`.",
  "type": "object",
  "required": ["version", "generated_from", "agents"],
  "properties": {
    "$schema": {"type": "string"},
    "version": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}(\\.\\d+)?$"
    },
    "generated_from": {"type": "string"},
    "agents": {
      "type": "array",
      "items": {"$ref": "#/definitions/agentEntry"}
    }
  },
  "additionalProperties": false,
  "definitions": {
    "agentEntry": {
      "type": "object",
      "required": ["name", "path", "description", "aliases", "keywords", "file_patterns", "delegate_when"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "path": {
          "type": "string",
          "description": "Path relative to agents/ root, posix separators"
        },
        "description": {"type": "string"},
        "aliases": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "keywords": {
          "type": "array",
          "description": "Match phrases for the agent-suggest hook. Substring-matched against prompt text.",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "file_patterns": {
          "type": "array",
          "description": "Glob patterns. When any changed file matches, the agent becomes a suggestion candidate.",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "delegate_when": {
          "type": "array",
          "description": "Delegation signals. When the prompt contains phrasing aligned with any of these signals, agent-suggest surfaces the agent under 'Delegate:' in addition to 'Consult:'. Empty list means consultation-only.",
          "items": {
            "type": "string",
            "enum": ["isolation", "independence", "parallel", "large_scope"]
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  }
}

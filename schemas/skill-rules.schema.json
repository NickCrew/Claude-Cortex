{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/NickCrew/claude-cortex/schemas/skill-rules.schema.json",
  "title": "Skill Rules",
  "description": "Keyword-based skill recommendation rules for cortex",
  "type": "object",
  "required": ["version", "rules"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version date (YYYY-MM-DD format)",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}(\\.\\d+)?$"
    },
    "rules": {
      "type": "array",
      "description": "List of skill matching rules",
      "items": {
        "$ref": "#/definitions/skillRule"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "skillRule": {
      "type": "object",
      "required": ["name", "command", "description", "keywords"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique identifier for the skill rule",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "command": {
          "type": "string",
          "description": "Slash command to invoke the skill",
          "pattern": "^/[a-z][a-z0-9:-]*$"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of what the skill does",
          "minLength": 10,
          "maxLength": 200
        },
        "keywords": {
          "type": "array",
          "description": "Keywords that trigger this skill recommendation",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  }
}

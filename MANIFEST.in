# MANIFEST.in - Include additional files in source distribution

# Documentation
include README.md
include LICENSE
include CREDITS.md
include CHANGELOG.md

# Manpages (generated, kept in docs/reference/)
recursive-include docs/reference *.1

# User-facing documentation (from site/)
recursive-include site/getting-started *.md
recursive-include site/guides *.md
recursive-include site/tutorials *.md
recursive-include site/reference *.md
include site/index.md

# Cortex content directories
recursive-include agents *.md *.json *.yaml *.yml *.toml
recursive-include skills *.md *.sh *.py *.json *.yaml *.yml *.toml
recursive-include hooks *.py *.json *.md
recursive-include rules *.md
recursive-include schemas *.json *.yaml *.yml
recursive-include scripts *.sh *.py *.md
recursive-include bin *
recursive-include codex *.md *.sh *.py *.json *.yaml *.yml
recursive-include gemini *.md *.sh *.py *.json *.yaml *.yml

global-exclude *PLAN*.md *SUMMARY*.md *IMPLEMENTATION*.md *REPORT*.md *COMPLETE*.md *ANALYSIS*.md *ACTIONS*.md Gemfile*

# Exclude non-bundled docs content
prune docs/vendor
prune docs/_site
prune docs/archive
prune docs/development
prune docs/features
prune docs/guides
prune docs/tutorials
prune docs/architecture
prune docs/presentations
prune docs/reviews
prune docs/diagrams
prune docs/assets
# Exclude Jekyll build artifacts from site/
prune site/_site
prune site/_sass
prune site/assets

# Scripts
recursive-include scripts *.sh

# Tests
recursive-include tests *.py

# Configuration examples
include pyproject.toml
include justfile

# Exclude build artifacts
global-exclude *.pyc
global-exclude *.pyo
global-exclude __pycache__
global-exclude .DS_Store
global-exclude *.egg-info
global-exclude dist

# Exclude state files
global-exclude intelligence/*
global-exclude tasks/*
global-exclude htmlcov/*

# Exclude caches
global-exclude .pytest_cache
global-exclude .mypy_cache
global-exclude .fastembed_cache

# Exclude development artifacts
global-exclude .metrics
global-exclude .code
global-exclude .codanna
global-exclude .coverage
global-exclude .claude
global-exclude .githooks
global-exclude .github
global-exclude .codacy
global-exclude coverage.xml 
global-exclude AGENTS.md GEMINI.md CLAUDE.md 
global-exclude .claudeignore
global-exclude .codannaignore
global-exclude *.ini

# Exclude virtual environments
global-exclude .venv
global-exclude .venv-*
global-exclude venv
